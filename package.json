{
  "name": "orbcafe-ui",
  "version": "1.2.3",
  "description": "Awesome UI components with Glassmorphism",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "check:ai-contracts": "node scripts/check-ai-contracts.js",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "pack:check": "npm_config_cache=/tmp/.npm-cache npm pack --dry-run",
    "release:check": "npm run check:ai-contracts && npm run build && npm run pack:check",
    "publish:npm": "npm publish --access public",
    "publish:npm:token": "./scripts/publish-npm.sh"
  },
  "keywords": [
    "react",
    "tailwind",
    "ui"
  ],
  "author": "ORBAI Team",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "next": "^16.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.35.1",
    "i18next": "^25.8.18",
    "lucide-react": "^0.475.0",
    "mermaid": "^10.9.0",
    "next-themes": "^0.3.0",
    "ogl": "^1.0.11",
    "react-i18next": "^16.5.8",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "overrides": {
    "rollup": "^4.59.0"
  }
}
